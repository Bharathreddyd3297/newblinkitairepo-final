# =====================================================
# Payment Service Environment Variables (sample)
# Copy to .env and update values for your environment.
# =====================================================

# ---- PostgreSQL ----
POSTGRES_DB=blinkit_payments
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Spring Datasource (consumed by application.yml) ----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5436/blinkit_payments
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ---- JWT ----
# Must match the secret used by auth-service / product-service / cart-service / order-service.
# HS512, >= 64 bytes recommended.
JWT_SECRET=replace-me-with-a-strong-512-bit-secret-replace-me-with-a-strong-512-bit-secret

# ---- Downstream services ----
ORDER_SERVICE_BASE_URL=http://localhost:8084

# ---- Payment simulation ----
# Percent of automatic-mode payments that should settle as SUCCESS (rest become FAILED).
# Range 0..100. Override per-request via the simulateStatus body field.
PAYMENT_SUCCESS_RATE_PERCENT=80

# ---- JVM (optional) ----
JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0
