# Environment Variables Template

# Copy this file to .env and fill in your values
# Use this for local development and Docker setup

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/blinkit_auth
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long-here
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8081
SERVER_SERVLET_CONTEXT_PATH=/

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BLINKIT_AUTHSERVICE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

# Application Name
SPRING_APPLICATION_NAME=auth-service

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# Profile (dev, prod)
SPRING_PROFILES_ACTIVE=prod

# JVM Options
JAVA_OPTS=-Xmx1024m -Xms512m

# For Docker Compose
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/blinkit_auth
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres

# Production Notes:
# 1. Generate secure JWT_SECRET using: openssl rand -base64 32
# 2. Use strong database password
# 3. Set SPRING_PROFILES_ACTIVE=prod for production
# 4. Configure external PostgreSQL instance
# 5. Set appropriate JVM memory settings
# 6. Enable HTTPS/TLS
# 7. Use environment-specific configuration
