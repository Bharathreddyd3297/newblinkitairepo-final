# =============================================================================
# frontend ClusterIP — fronted by the Ingress on `/` and `/index.html`.
# Switch type to LoadBalancer if you want a direct public IP without Ingress.
# =============================================================================
apiVersion: v1
kind: Service
metadata:
  name: frontend
  namespace: blinkit
  labels:
    app: frontend
spec:
  type: LoadBalancer
  selector:
    app: frontend
  ports:
  - name: http
    port: 80
    targetPort: 80
