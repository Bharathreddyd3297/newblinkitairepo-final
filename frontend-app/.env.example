# =============================================================================
# Blinkit Frontend — Environment Configuration
#
# Copy this file to `.env` (and `.env.production` for prod builds).
# All Vite-exposed vars MUST be prefixed with VITE_ — anything else stays
# server-side only and is not bundled into the client.
# =============================================================================

# API Gateway base URL. The frontend talks to NOTHING ELSE.
# Local dev:        http://localhost:8080
# AKS (cluster):    https://api.blinkit.example.com
VITE_API_BASE_URL=http://localhost:8080

# API request timeout (ms)
VITE_API_TIMEOUT=15000

# JWT storage key (override only if you need to namespace deployments)
VITE_AUTH_STORAGE_KEY=blinkit.auth

# Build identification (surfaced in footer / debug menus)
VITE_APP_NAME=Blinkit
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# Feature flags
VITE_ENABLE_3D=true
VITE_ENABLE_PARTICLES=true
VITE_ENABLE_DEVTOOLS=true
