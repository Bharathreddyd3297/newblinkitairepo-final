# =============================================================================
# Blinkit AI Recommendation Service — environment template
# -----------------------------------------------------------------------------
# Copy to .env and edit. The .env file is intentionally NOT committed.
# All knobs default to safe dev values inside app/core/config.py if missing.
# =============================================================================

# --- Service identity ---
SERVICE_NAME=ai-recommendation-service
SERVICE_PORT=8090
ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- product-service integration ---
# Inside docker-compose, this is Docker DNS. Outside docker, use http://localhost:8082.
PRODUCT_SERVICE_BASE_URL=http://product-service:8082
PRODUCT_SERVICE_TIMEOUT_SECONDS=5
PRODUCT_SERVICE_PAGE_SIZE=100
PRODUCT_SERVICE_MAX_PAGES=10

# Optional fallback bearer token used when no inbound Authorization
# header is present (warm-up jobs, local development). Leave blank in
# environments where the API Gateway always forwards an end-user JWT.
INTERNAL_SERVICE_JWT=

# --- Redis ---
# IMPORTANT: in docker-compose this is the service DNS name `redis`,
# NEVER `localhost`. Outside docker use localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=reco
REDIS_SOCKET_TIMEOUT_SECONDS=2

# --- TTLs (seconds) ---
TTL_TRENDING_SECONDS=300
TTL_RELATED_SECONDS=3600
TTL_FREQUENTLY_BOUGHT_SECONDS=3600
TTL_USER_SECONDS=300
TTL_CATALOG_SNAPSHOT_SECONDS=600

# --- Top-K tuning ---
RELATED_TOP_K=5
FREQUENTLY_BOUGHT_TOP_K=5
TRENDING_TOP_K=10
USER_TOP_K=10

# --- Embedding backend ---
# auto = sentence-transformers when available, TF-IDF as fallback.
# Force `tfidf` in CI / lightweight builds to avoid a 400MB torch download.
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=10000
