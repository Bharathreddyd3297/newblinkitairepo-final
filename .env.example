# =============================================================================
# Blinkit Microservices Platform — Root Environment Configuration (sample)
# =============================================================================
# Copy this file to `.env` at the same level (workspace root) and adjust the
# values for your environment. Docker Compose will load `.env` automatically
# when you run `docker compose -f docker-compose.platform.yml up`.
#
# In production this file MUST NOT be committed. Real values should come from:
#   - Kubernetes Secrets (mounted as env vars on each Pod), or
#   - Azure Key Vault (via CSI driver / workload identity), or
#   - Azure DevOps variable groups (for CI/CD pipelines).
# =============================================================================

# -----------------------------------------------------------------------------
# Shared JWT signing secret (HS512)
# -----------------------------------------------------------------------------
# CRITICAL: every microservice (auth-service, product-service, cart-service)
# MUST read the SAME value. auth-service signs tokens with this secret;
# product-service and cart-service validate incoming tokens with it.
#
# Algorithm: HS512 (HMAC-SHA-512). The JJWT library requires the raw key bytes
# to be at least 64 bytes for HS512. The example value below is short and is
# intended only as a placeholder — for any real environment, replace it with
# a randomly generated secret of >= 64 bytes (e.g. `openssl rand -base64 96`).
# -----------------------------------------------------------------------------
JWT_SECRET=mySuperSecureBlinkitSecretKeyForHS512Authentication123456789

# -----------------------------------------------------------------------------
# Shared PostgreSQL credentials
# -----------------------------------------------------------------------------
# Each service still owns its own logical database (blinkit_auth,
# blinkit_products, blinkit_cart) — these are just the credentials all
# services share to connect to their respective Postgres instances.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
