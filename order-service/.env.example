# =====================================================
# Order Service Environment Variables (sample)
# Copy to .env and update values for your environment.
# =====================================================

# ---- PostgreSQL ----
POSTGRES_DB=blinkit_orders
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Spring Datasource (consumed by application.yml) ----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/blinkit_orders
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ---- JWT ----
# Must match the secret used by auth-service / product-service / cart-service.
# HS512, >= 64 bytes recommended.
JWT_SECRET=replace-me-with-a-strong-512-bit-secret-replace-me-with-a-strong-512-bit-secret

# ---- Downstream services ----
CART_SERVICE_BASE_URL=http://localhost:8083
PRODUCT_SERVICE_BASE_URL=http://localhost:8082

# ---- JVM (optional) ----
JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0
