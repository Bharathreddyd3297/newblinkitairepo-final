# =============================================================================
# api-gateway — environment template
# -----------------------------------------------------------------------------
# Copy to .env (NEVER commit the real .env). Values shown here are safe
# development defaults; production values come from Azure Key Vault via
# the Secrets Store CSI driver.
# =============================================================================

# ------------------------------------------------------------------
# Distributed JWT trust — MUST match every other Blinkit service.
# >= 64 bytes for HS512.
# ------------------------------------------------------------------
JWT_SECRET=change-me-to-a-64-byte-random-secret-shared-across-every-blinkit-service

# ------------------------------------------------------------------
# Redis — used by the per-IP rate limiter. The gateway fails open if
# Redis is unreachable, but rate limiting will not be enforced in
# that mode, so don't run prod without it.
# ------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------
# Per-IP request budget (default: 100 / minute).
# ------------------------------------------------------------------
RATE_LIMIT_RPM=100

# ------------------------------------------------------------------
# Downstream service URIs. Defaults match Docker DNS in the platform
# compose file. Override when running the gateway against locally
# started services.
# ------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:8081
PRODUCT_SERVICE_URL=http://product-service:8082
CART_SERVICE_URL=http://cart-service:8083
ORDER_SERVICE_URL=http://order-service:8084
PAYMENT_SERVICE_URL=http://payment-service:8085
AI_RECOMMENDATION_SERVICE_URL=http://ai-recommendation-service:8090
